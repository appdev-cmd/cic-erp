{
  "name": "cic-telegram-openclaw",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Worker OpenClaw-style: Telegram @cic_vn_bot + Gemma (Ollama) + RPC an toàn Supabase",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --outdir=dist --format=esm --packages=external",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "webhook:set": "node scripts/set-webhook-from-env.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.91.1",
    "docx": "^9.6.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "mammoth": "^1.6.0",
    "p-queue": "^9.1.2",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.18.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.17.5",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "~5.8.2"
  }
}
