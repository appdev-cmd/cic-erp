{
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                { "key": "X-Content-Type-Options", "value": "nosniff" },
                { "key": "X-Frame-Options", "value": "DENY" },
                { "key": "X-XSS-Protection", "value": "1; mode=block" },
                { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
                { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/api/vllm_gemma/(.*)",
            "destination": "https://ai-api.cic.com.vn:8002/v1/$1"
        },
        {
            "source": "/api/vllm/(.*)",
            "destination": "https://ai-api.cic.com.vn:4000/v1/$1"
        },
        {
            "source": "/api/ollama/(.*)",
            "destination": "https://ai-api.cic.com.vn:11434/v1/$1"
        },
        {
            "source": "/api/ollama_native/(.*)",
            "destination": "https://ai-api.cic.com.vn:11434/api/$1"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}